<section class="hero_panel">
            <div>
              <span class="mini_badge">
                <span class="material-symbols-rounded">verified</span>
                <%= safeSubAdminTitle %>
              </span>

              <h2>Halo, <%= safeUser.nama || 'Sub Admin' %></h2>

              <p>
                Anda login sebagai sub admin. Anda tetap dapat membuat surat sendiri seperti user biasa, sekaligus mengelola user dan surat dari bagian yang berada di bawah kewenangan Anda.
              </p>

              <div class="subadmin_scope_inline">
                <% if (safeBagianDibawahi.length > 0) { %>
                  <% safeBagianDibawahi.forEach(function(bagian) { %>
                    <span class="bagian_pill">
                      <span class="material-symbols-rounded">business_center</span>
                      <%= bagian %>
                    </span>
                  <% }) %>
                <% } else { %>
                  <span class="bagian_pill bagian_empty">
                    <span class="material-symbols-rounded">warning</span>
                    Belum ada bagian dibawahi
                  </span>
                <% } %>
              </div>
            </div>

            <div class="avatar_orb">
              <%= (safeUser.nama || '?').charAt(0).toUpperCase() %>
            </div>
          </section>
