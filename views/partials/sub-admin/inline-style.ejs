  display: flex;
  flex-direction: column;
  gap: clamp(14px, 2vw, 24px);
}

/* ---------- FOOTER ---------- */

.app_footer {
  margin-top: 24px;
  padding: 16px 22px;
  border-radius: 22px;
  border: 1px solid var(--panel-border);
  background: var(--panel-bg);
  color: #cbd5e1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  font-size: 13px;
  font-weight: 700;
  box-shadow: 0 14px 34px rgba(15, 23, 42, 0.10);
}

