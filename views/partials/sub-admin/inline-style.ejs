/* ---------- STATISTIC SECTION ---------- */

.subadmin_scope_inline {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 16px;
}

.subadmin_stat_grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 18px;
}

.subadmin_stat_card {
  min-height: 132px;
  border: 1px solid var(--panel-border);
  overflow: hidden;
  position: relative;
  box-shadow: 0 18px 50px rgba(15, 23, 42, 0.14);
}

.subadmin_stat_card::after {
  content: "";
  position: absolute;
  right: -44px;
  bottom: -44px;
  width: 132px;
  height: 132px;
  border-radius: 999px;
  background: rgba(37, 99, 235, 0.12);
}

.subadmin_stat_card > span.material-symbols-rounded {
  width: 40px;
  height: 40px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 14px;
  background: rgba(37, 99, 235, 0.12);
  color: #60a5fa;
  margin-bottom: 10px;
}

.subadmin_stat_card h3 {
  font-size: 13px;
  margin-bottom: 8px;
}

.subadmin_stat_card p b {
  font-size: 28px;
  line-height: 1;
}

@media (max-width: 1200px) {
  .subadmin_stat_grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 768px) {
  .subadmin_stat_grid {
    grid-template-columns: 1fr;
    gap: 10px;
  }

  .subadmin_stat_card {
    min-height: 104px;
    padding: 14px !important;
    border-radius: 16px !important;
  }

  .subadmin_stat_card > span.material-symbols-rounded {
    width: 34px;
    height: 34px;
    font-size: 19px;
  }

  .subadmin_stat_card h3 {
    font-size: 12px;
  }

  .subadmin_stat_card p b {
    font-size: 24px;
  }
}

/* ---------- PANEL AND SECTION ---------- */

.settings_section,
.subadmin_panel_section {
  padding: 20px !important;
  border-radius: 20px !important;
  border: 1px solid var(--panel-border);
  background: var(--panel-bg);
  color: var(--table-text);
  box-shadow: var(--panel-shadow);
  backdrop-filter: blur(18px);
}

.section_header {
  margin-bottom: 16px !important;
  gap: 10px !important;
}

.section_header h2 {
  display: flex;
  align-items: center;
  gap: 9px;
  font-size: 18px !important;
  line-height: 1.3 !important;
  letter-spacing: -0.02em;
}

.section_header h2 .material-symbols-rounded {
  font-size: 21px !important;
}

.section_header p {
  max-width: 780px;
  font-size: 12.5px !important;
  line-height: 1.5 !important;
}

@media (max-width: 768px) {
  .settings_section,
  .subadmin_panel_section {
    padding: 12px !important;
    border-radius: 15px !important;
  }

  .section_header {
    margin-bottom: 11px !important;
  }

  .section_header h2 {
    font-size: 15px !important;
    gap: 6px !important;
  }

  .section_header h2 .material-symbols-rounded {
    font-size: 18px !important;
  }

  .section_header p {
    font-size: 10.5px !important;
  }
}

@media (max-width: 430px) {
  .settings_section,
  .subadmin_panel_section {
    padding: 10px !important;
    border-radius: 14px !important;
  }

  .section_header h2 {
    font-size: 14px !important;
  }

  .section_header p {
    font-size: 10px !important;
  }
}

/* ---------- FORM COMPACT ---------- */

.sinosuke_form {
  width: 100%;
}

.form_grid {
  gap: 12px !important;
}

.form_grid.single_column {
  grid-template-columns: 1fr !important;
}

.input_group {
  gap: 6px !important;
}

.group_label {
  margin-bottom: 5px !important;
  font-size: 10.5px !important;
  line-height: 1.2 !important;
  letter-spacing: 0.06em !important;
}

.helper_text {
  margin-top: 5px !important;
  font-size: 10.5px !important;
  line-height: 1.4 !important;
  color: var(--form-muted) !important;
}

.styled_input,
.subadmin_search_input,
.admin_search_input,
.admin_bagian_search_input,
.search_select_input {
  height: 36px !important;
  min-height: 36px !important;
  padding: 0 11px !important;
  border-radius: 12px !important;
  font-size: 11px !important;
  line-height: 1.3 !important;
  background: var(--form-bg) !important;
  border: 1px solid var(--form-border) !important;
  color: var(--form-text) !important;
}

textarea.styled_input,
.subadmin_textarea,
.admin_textarea {
  height: auto !important;
  min-height: 76px !important;
  padding: 10px 11px !important;
  border-radius: 13px !important;
  resize: vertical;
  font-size: 11px !important;
  line-height: 1.45 !important;
}

.styled_input:focus,
.subadmin_search_input:focus,
.admin_search_input:focus,
.admin_bagian_search_input:focus,
.search_select_input:focus {
  border-color: var(--form-focus) !important;
  box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12) !important;
  outline: none !important;
}

.form_actions {
  margin-top: 12px !important;
  display: flex !important;
  align-items: center !important;
  justify-content: flex-start !important;
  gap: 10px !important;
  flex-wrap: wrap !important;
}

.primary_btn {
  width: auto !important;
  min-width: 0 !important;
  height: 34px !important;
  min-height: 34px !important;
  padding: 0 12px !important;
  border-radius: 999px !important;
  font-size: 10.5px !important;
  line-height: 1 !important;
  gap: 6px !important;
}

.primary_btn .material-symbols-rounded {
  font-size: 15px !important;
}

/* ---------- SEARCH AREA ---------- */

.subadmin_search_wrapper,
.admin_search_wrapper {
  display: flex;
  align-items: center;
  gap: 8px !important;
  margin-bottom: 12px !important;
  flex-wrap: wrap;
}

.subadmin_search_box,
.admin_search_box {
  flex: 1;
  min-width: 220px !important;
  min-height: 38px !important;
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 0 11px !important;
  border-radius: 13px !important;
  border: 1px solid var(--form-border) !important;
  background: var(--form-bg) !important;
}

.subadmin_search_box:focus-within,
.admin_search_box:focus-within {
  border-color: var(--form-focus) !important;
  box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12) !important;
}

.subadmin_search_box .material-symbols-rounded,
.admin_search_box .material-symbols-rounded {
  font-size: 17px !important;
  color: var(--form-muted);
}

.subadmin_search_input,
.admin_search_input {
  width: 100%;
  height: 36px !important;
  border: 0 !important;
  outline: none !important;
  background: transparent !important;
  color: inherit !important;
  font: inherit !important;
}

.subadmin_search_clear,
.admin_search_clear {
  width: auto !important;
  min-width: 0 !important;
  max-width: max-content !important;
  height: 32px !important;
  min-height: 32px !important;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 5px !important;
  border-radius: 999px !important;
  padding: 0 11px !important;
  border: 1px solid var(--form-border) !important;
  background: rgba(148, 163, 184, 0.10);
  color: inherit;
  font-size: 10px !important;
  font-weight: 850;
  cursor: pointer;
}

.subadmin_search_clear .material-symbols-rounded,
.admin_search_clear .material-symbols-rounded {
  font-size: 15px !important;
}

@media (max-width: 768px) {
  .form_grid {
    grid-template-columns: 1fr !important;
    gap: 10px !important;
  }

  .styled_input,
  .subadmin_search_input,
  .admin_search_input,
  .admin_bagian_search_input,
  .search_select_input {
    height: 34px !important;
    min-height: 34px !important;
    font-size: 10.5px !important;
  }

  textarea.styled_input,
  .subadmin_textarea,
  .admin_textarea {
    min-height: 70px !important;
    font-size: 10.5px !important;
  }

  .primary_btn {
    height: 32px !important;
    min-height: 32px !important;
    padding: 0 10px !important;
    font-size: 10px !important;
  }

  .subadmin_search_wrapper,
  .admin_search_wrapper {
    flex-direction: column !important;
    align-items: stretch !important;
  }

  .subadmin_search_box,
  .admin_search_box {
    width: 100% !important;
    min-width: 0 !important;
  }

  .subadmin_search_clear,
  .admin_search_clear {
    width: max-content !important;
  }
}

@media (max-width: 430px) {
  .styled_input,
  .subadmin_search_input,
  .admin_search_input,
  .admin_bagian_search_input,
  .search_select_input {
    height: 32px !important;
    min-height: 32px !important;
    font-size: 10px !important;
  }

  textarea.styled_input,
  .subadmin_textarea,
  .admin_textarea {
    min-height: 64px !important;
  }

  .primary_btn {
    height: 30px !important;
    min-height: 30px !important;
    font-size: 9.8px !important;
  }
}

/* ---------- TABLE COMPACT ---------- */

.subadmin_table_wrapper {
  width: 100% !important;
  max-width: 100% !important;
  overflow-x: auto !important;
  overflow-y: visible !important;
  border-radius: 16px !important;
  border: 1px solid var(--panel-border);
  background: rgba(15, 23, 42, 0.14);
  -webkit-overflow-scrolling: touch;
}

.subadmin_table {
  width: 100% !important;
  border-collapse: separate !important;
  border-spacing: 0 !important;
  table-layout: auto !important;
  overflow: hidden;
}

#akunBawahanSection .subadmin_table {
  min-width: 720px !important;
}

#whitelistSection .subadmin_table,
.whitelist_table {
  min-width: 680px !important;
}

#suratBawahanSection .subadmin_table,
.surat_bawahan_table {
  min-width: 1120px !important;
}

.subadmin_table thead th {
  position: sticky;
  top: 0;
  z-index: 5;
  padding: 11px 12px !important;
  font-size: 10.5px !important;
  line-height: 1.2 !important;
  font-weight: 850;
  letter-spacing: 0.035em;
  text-transform: uppercase;
  color: var(--table-head-text);
  background: var(--table-head-bg);
  border-bottom: 1px solid var(--panel-border);
  white-space: nowrap !important;
}

.subadmin_table tbody td {
  padding: 11px 12px !important;
  font-size: 12px !important;
  line-height: 1.3 !important;
  vertical-align: middle !important;
  border-bottom: 1px solid rgba(148, 163, 184, 0.12);
  color: var(--table-text);
  background: var(--table-cell-bg);
}

.subadmin_table tbody tr:nth-child(even) td {
  background: var(--table-cell-alt-bg);
}

.subadmin_table tbody tr:hover td {
