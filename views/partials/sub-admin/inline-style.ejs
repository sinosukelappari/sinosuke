.app_footer_right {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-width: 0;
}

.app_footer_left .material-symbols-rounded {
  font-size: 20px;
  color: #93c5fd;
}

.app_footer_right {
  color: var(--table-muted);
  text-align: right;
}

