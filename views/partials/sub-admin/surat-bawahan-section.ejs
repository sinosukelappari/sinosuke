<%
  function normalizeJenisSurat(value) {
    const jenisSurat = String(value || "")
      .trim()
      .toUpperCase()
      .replace(/\s+/g, "_");

    if (jenisSurat === "SURAT_BIASA") {
      return "SURAT_BIASA";
    }

    if (jenisSurat === "SURAT_KEPUTUSAN") {
      return "SURAT_KEPUTUSAN";
    }

    return "SURAT_KEPUTUSAN";
  }

  function getJenisSuratLabel(value) {
    const jenisSurat = normalizeJenisSurat(value);

    if (jenisSurat === "SURAT_BIASA") {
      return "Biasa";
    }

    return "Keputusan";
  }

  function getJenisSuratIcon(value) {
    const jenisSurat = normalizeJenisSurat(value);

    if (jenisSurat === "SURAT_BIASA") {
      return "mail";
    }

    return "gavel";
  }

  function getJenisSuratClass(value) {
    const jenisSurat = normalizeJenisSurat(value);

    if (jenisSurat === "SURAT_BIASA") {
      return "jenis_surat_biasa";
    }

    return "jenis_surat_keputusan";
  }

  function getFormatNomorSurat(value) {
    const jenisSurat = normalizeJenisSurat(value);

   
  }
%>

