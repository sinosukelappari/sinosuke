    border: 1px solid rgba(96, 165, 250, 0.28);
    color: #bfdbfe;
    padding: 8px 11px;
    border-radius: 999px;
    font-weight: 800;
    white-space: nowrap;
    cursor: pointer;
  }

  .sheet_row_link:hover {
    background: rgba(37, 99, 235, 0.22);
    color: #ffffff;
    text-decoration: none;
  }

  .sheet_row_link .material-symbols-rounded {
    font-size: 17px;
  }

  .sheet_row_empty {
    color: var(--text-muted, #94a3b8);
    font-weight: 700;
  }

