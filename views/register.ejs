<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">

  <title>Register User</title>

  <meta name="viewport" content="width=device-width, initial-scale=1">

  <link 
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" 
    rel="stylesheet"
  >

  <link 
    href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,0,0" 
    rel="stylesheet"
  >

  <link rel="stylesheet" href="/style.css">

  <style>
    :root {
      --auth-bg-1: #0f172a;
      --auth-bg-2: #1e293b;
      --auth-card: rgba(255, 255, 255, 0.96);
      --auth-text: #0f172a;
      --auth-muted: #64748b;
      --auth-primary: #2563eb;
      --auth-primary-dark: #1d4ed8;
      --auth-border: #e2e8f0;
      --auth-danger-bg: #fef2f2;
      --auth-danger-text: #b91c1c;
      --auth-success-bg: #f0fdf4;
      --auth-success-text: #15803d;
    }

    body.auth-body {
      min-height: 100vh;
      margin: 0;
      background:
        radial-gradient(circle at top left, rgba(37, 99, 235, 0.35), transparent 35%),
        radial-gradient(circle at bottom right, rgba(14, 165, 233, 0.22), transparent 35%),
        linear-gradient(135deg, var(--auth-bg-1), var(--auth-bg-2));
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--auth-text);
    }

    .auth-wrapper {
      min-height: 100vh;
      padding: 24px;
    }

    .auth-card {
      width: 100%;
      max-width: 500px;
      border-radius: 28px;
      background: var(--auth-card);
      overflow: visible;
      position: relative;
    }

    .auth-card::before {
      content: "";
      position: absolute;
      inset: 0 0 auto 0;
      height: 7px;
      background: linear-gradient(90deg, #2563eb, #38bdf8, #60a5fa);
      border-top-left-radius: 28px;
      border-top-right-radius: 28px;
    }

    .auth-logo {
      width: 64px;
      height: 64px;
      border-radius: 22px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #2563eb, #60a5fa);
      color: #ffffff;
      box-shadow: 0 16px 36px rgba(37, 99, 235, 0.28);
      margin-bottom: 18px;
    }

    .auth-logo .material-symbols-rounded {
      font-size: 34px;
    }

    .auth-title {
      font-weight: 800;
      letter-spacing: -0.03em;
      margin-bottom: 6px;
    }

    .auth-subtitle {
      color: var(--auth-muted);
      font-size: 15px;
      line-height: 1.55;
      margin-bottom: 0;
    }

    .auth-alert {
      border: 0;
      border-radius: 18px;
      padding: 14px 16px;
      font-size: 14px;
      line-height: 1.5;
    }

    .auth-alert-danger {
      background: var(--auth-danger-bg);
      color: var(--auth-danger-text);
    }

    .auth-alert-success {
      background: var(--auth-success-bg);
      color: var(--auth-success-text);
    }

    .auth-label {
      font-weight: 700;
      color: #1e293b;
      margin-bottom: 8px;
    }

    .auth-input-wrap {
      position: relative;
    }

    .auth-input-icon {
      position: absolute;
      left: 16px;
      top: 50%;
      transform: translateY(-50%);
      color: #94a3b8;
      font-size: 21px;
      pointer-events: none;
    }

    .custom-input.auth-input {
      height: 54px;
      border-radius: 17px;
      border: 1px solid var(--auth-border);
      padding-left: 48px;
      font-size: 15px;
      box-shadow: none;
      transition: border-color 0.16s ease, box-shadow 0.16s ease;
    }

    .custom-input.auth-input:focus {
      border-color: #60a5fa;
      box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.12);
    }

    .auth-helper {
      display: block;
      margin-top: 7px;
      color: var(--auth-muted);
      font-size: 13px;
      line-height: 1.45;
    }

    .auth-helper.invalid {
      color: var(--auth-danger-text);
      font-weight: 600;
    }

    .auth-helper.valid {
      color: var(--auth-success-text);
      font-weight: 600;
    }

    .btn-main.auth-submit {
      height: 54px;
      border-radius: 999px;
      border: 0;
      background: linear-gradient(135deg, var(--auth-primary), #60a5fa);
      color: #ffffff;
      font-weight: 800;
      box-shadow: 0 16px 32px rgba(37, 99, 235, 0.24);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      transition: opacity 0.16s ease, box-shadow 0.16s ease, background 0.16s ease;
    }

    .btn-main.auth-submit:hover:not(:disabled) {
      background: linear-gradient(135deg, var(--auth-primary-dark), #3b82f6);
      color: #ffffff;
    }

    .btn-main.auth-submit:disabled {
      background: #94a3b8;
      color: #ffffff;
      opacity: 0.65;
      cursor: not-allowed;
      box-shadow: none;
    }

    .auth-link {
      color: var(--auth-primary);
      font-weight: 800;
      text-decoration: none;
    }

    .auth-link:hover {
      color: var(--auth-primary-dark);
      text-decoration: underline;
    }

    .auth-note {
      margin-top: 18px;
      border-radius: 18px;
      background: #eff6ff;
      color: #1e40af;
      padding: 13px 15px;
      display: flex;
      gap: 10px;
      align-items: flex-start;
      font-size: 13px;
      line-height: 1.45;
    }

    .auth-note .material-symbols-rounded {
      font-size: 20px;
      flex: 0 0 auto;
    }

    .search_select {
      position: relative;
    }

    .search_select_input {
      cursor: text;
      padding-left: 48px !important;
      padding-right: 48px !important;
    }

    .search_select_icon {
      position: absolute;
      left: 16px;
      top: 50%;
      transform: translateY(-50%);
      color: #94a3b8;
      font-size: 21px;
      pointer-events: none;
      z-index: 2;
    }

    .search_select_toggle,
    .search_clear_btn {
      position: absolute;
      right: 12px;
      top: 50%;
      transform: translateY(-50%);
      width: 34px;
      height: 34px;
      border: 0;
      border-radius: 999px;
      background: #f1f5f9;
      color: #64748b;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      z-index: 3;
    }

    .search_select_toggle:hover,
    .search_clear_btn:hover {
      background: #e2e8f0;
      color: #0f172a;
    }

    .search_select_toggle .material-symbols-rounded,
    .search_clear_btn .material-symbols-rounded {
      font-size: 20px;
    }

    .search_dropdown {
      position: absolute;
      top: calc(100% + 8px);
      left: 0;
      right: 0;
      z-index: 50;
      max-height: 280px;
      overflow-y: auto;
      padding: 8px;
      border-radius: 18px;
      background: #ffffff;
      border: 1px solid #e2e8f0;
      box-shadow: 0 20px 45px rgba(15, 23, 42, 0.18);
    }

    .search_dropdown.hidden {
      display: none;
    }

    .dropdown_option {
      width: 100%;
      border: 0;
      background: transparent;
      padding: 11px 12px;
      border-radius: 14px;
      text-align: left;
      display: flex;
      gap: 10px;
      align-items: flex-start;
      cursor: pointer;
      color: #0f172a;
    }

    .dropdown_option:hover {
      background: #eff6ff;
    }

    .dropdown_option.disabled {
      cursor: not-allowed;
      opacity: 0.58;
    }

    .dropdown_option.disabled:hover {
      background: transparent;
    }

    .dropdown_icon {
      width: 36px;
      height: 36px;
      border-radius: 13px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #2563eb, #60a5fa);
      color: #ffffff;
      flex: 0 0 auto;
    }

    .dropdown_icon.full {
      background: linear-gradient(135deg, #ef4444, #f97316);
    }

    .dropdown_text {
      display: flex;
      flex-direction: column;
      gap: 3px;
      min-width: 0;
      flex: 1;
    }

    .dropdown_text strong {
      font-size: 14px;
      font-weight: 800;
      color: #0f172a;
    }

    .dropdown_text small {
      font-size: 12px;
      color: #64748b;
      line-height: 1.35;
    }

    .status_pill {
      margin-left: auto;
      display: inline-flex;
      align-items: center;
      gap: 5px;
      border-radius: 999px;
      padding: 5px 9px;
      font-size: 11px;
      font-weight: 800;
      white-space: nowrap;
    }

    .status_available {
      background: #dcfce7;
      color: #15803d;
    }

    .status_full {
      background: #fee2e2;
      color: #b91c1c;
    }

    .empty_dropdown {
      padding: 14px;
      color: #64748b;
      font-size: 14px;
      text-align: center;
    }

    .hidden {
      display: none !important;
    }

    @media (max-width: 576px) {
      .auth-wrapper {
        padding: 16px;
      }

      .auth-card {
        border-radius: 24px;
      }

      .search_dropdown {
        max-height: 230px;
      }

      .status_pill {
        display: none;
      }
    }
  </style>
</head>

<body class="auth-body">

  <%
    const safeError = typeof error !== "undefined" && Array.isArray(error) ? error : [];
    const safeSuccess = typeof success !== "undefined" && Array.isArray(success) ? success : [];
    const safeBagianOptions = typeof bagianOptions !== "undefined" && Array.isArray(bagianOptions) ? bagianOptions : [];
  %>

  <main class="auth-wrapper d-flex align-items-center justify-content-center">
    <div class="auth-card card border-0 shadow-lg">
      <div class="card-body p-4 p-sm-5">

        <div class="text-center mb-4">
          <div class="auth-logo mx-auto">
            <span class="material-symbols-rounded">person_add</span>
          </div>

          <h3 class="auth-title">
            Buat Akun
          </h3>

          <p class="auth-subtitle">
            Daftar menggunakan username whitelist dan pilih bagian yang tersedia.
          </p>
        </div>

        <% if (safeError.length > 0) { %>
          <% safeError.forEach(function(message) { %>
            <div class="alert auth-alert auth-alert-danger">
              <%= message %>
            </div>
          <% }) %>
        <% } %>

        <% if (safeSuccess.length > 0) { %>
          <% safeSuccess.forEach(function(message) { %>
            <div class="alert auth-alert auth-alert-success">
              <%= message %>
            </div>
          <% }) %>
        <% } %>

        <form action="/register" method="POST" autocomplete="on" id="registerForm">

          <div class="mb-3">
            <label class="form-label auth-label" for="nama">
              Nama Lengkap
            </label>

            <div class="auth-input-wrap">
              <span class="material-symbols-rounded auth-input-icon">badge</span>

              <input 
                type="text" 
                name="nama" 
                id="nama"
                class="form-control form-control-lg custom-input auth-input" 
                placeholder="Masukkan nama lengkap"
                autocomplete="name"
                required
              >
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label auth-label" for="username">
              Nomor Induk Pegawai (NIP)
            </label>

            <div class="auth-input-wrap">
              <span class="material-symbols-rounded auth-input-icon">pin</span>

              <input 
                type="text" 
                name="username" 
                id="username"
                class="form-control form-control-lg custom-input auth-input" 
                placeholder="18 digit angka"
                inputmode="numeric"
                pattern="[0-9]{18}"
                minlength="18"
                maxlength="18"
                title="NIP harus berupa 18 digit angka"
                autocomplete="username"
                required
              >
            </div>

            <!-- <small class="auth-helper invalid" id="nipHelper">
              NIP wajib 18 digit angka.
            </small> -->
          </div>

          <div class="mb-3">
            <label class="form-label auth-label" for="bagianSearch">
              Bagian / Jabatan 
            </label>

            <input type="hidden" name="bagian" id="bagian">

            <div class="search_select">
              <span class="material-symbols-rounded search_select_icon">business_center</span>

              <input
                type="text"
                id="bagianSearch"
                class="form-control form-control-lg custom-input auth-input search_select_input"
                placeholder="Cari atau pilih bagian"
                autocomplete="off"
                required
              >

              <button 
                type="button"
                id="bagianToggle"
                class="search_select_toggle search_clear_btn"
                title="Hapus pilihan"
              >
                <span class="material-symbols-rounded">close</span>
              </button>

              <div id="bagianDropdown" class="search_dropdown hidden"></div>
            </div>

            <small class="auth-helper invalid" id="bagianHelper">
              Pilih bagian dari daftar. Bagian yang sudah penuh tidak dapat dipilih.
            </small>
          </div>

          <div class="mb-4">
            <label class="form-label auth-label" for="password">
              Password
            </label>

            <div class="auth-input-wrap">
              <span class="material-symbols-rounded auth-input-icon">lock</span>

              <input 
                type="password" 
                name="password" 
                id="password"
                class="form-control form-control-lg custom-input auth-input" 
                placeholder="Buat password"
                autocomplete="new-password"
                required
              >
            </div>
          </div>

          <button type="submit" class="btn btn-main auth-submit w-100" id="submitBtn" disabled>
            <span class="material-symbols-rounded">how_to_reg</span>
            Daftar User
          </button>
        </form>

        <div class="auth-note">
          <span class="material-symbols-rounded">info</span>
          <div>
            Jika bagian yang Anda cari tidak tersedia atau sudah penuh, silakan hubungi admin.
          </div>
        </div>

        <div class="text-center mt-4">
          <span class="text-secondary">Sudah punya akun?</span>
          <a href="/login" class="auth-link">Login</a>
        </div>

      </div>
    </div>
  </main>

  <textarea id="bagianRegisterOptionsJson" hidden><%= JSON.stringify(safeBagianOptions) %></textarea>

  <script>
    const bagianRegisterOptionsElement = document.getElementById("bagianRegisterOptionsJson");

    window.BAGIAN_REGISTER_OPTIONS = [];

    if (bagianRegisterOptionsElement) {
      try {
        const parsedBagianOptions = JSON.parse(bagianRegisterOptionsElement.value || "[]");

        window.BAGIAN_REGISTER_OPTIONS = Array.isArray(parsedBagianOptions)
          ? parsedBagianOptions
          : [];
      } catch (error) {
        window.BAGIAN_REGISTER_OPTIONS = [];

        console.error("Gagal membaca BAGIAN_REGISTER_OPTIONS:", error);
      }
    }
  </script>

  <script>
    (function () {
      const usernameInput = document.getElementById("username");
      const bagianOptions = Array.isArray(window.BAGIAN_REGISTER_OPTIONS)
        ? window.BAGIAN_REGISTER_OPTIONS
        : [];

      const hiddenInput = document.getElementById("bagian");
      const searchInput = document.getElementById("bagianSearch");
      const clearBtn = document.getElementById("bagianToggle");
      const dropdown = document.getElementById("bagianDropdown");
      const form = document.getElementById("registerForm");
      const submitBtn = document.getElementById("submitBtn");
      const nipHelper = document.getElementById("nipHelper");
      const bagianHelper = document.getElementById("bagianHelper");

      function escapeHTML(value) {
        return String(value || "")
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#039;");
      }

      function isNipValid() {
        return /^[0-9]{18}$/.test(usernameInput.value);
      }

      function isBagianValid() {
        return hiddenInput.value.trim().length > 0;
      }

      function updateHelperState(element, isValid, validText, invalidText) {
        if (!element) {
          return;
        }

        element.textContent = isValid ? validText : invalidText;
        element.classList.toggle("valid", isValid);
        element.classList.toggle("invalid", !isValid);
      }

      function updateSubmitState() {
        const nipValid = isNipValid();
        const bagianValid = isBagianValid();

        updateHelperState(
          nipHelper,
          nipValid,
          "NIP sudah valid.",
          "NIP wajib 18 digit angka."
        );

        updateHelperState(
          bagianHelper,
          bagianValid,
          "Bagian sudah dipilih.",
          "Pilih bagian dari daftar. Bagian yang sudah penuh tidak dapat dipilih."
        );

        if (submitBtn) {
          submitBtn.disabled = !(nipValid && bagianValid);
        }
      }

      function getBagianDescription(option) {
        if (option.isUnlimited) {
          return "Unlimited · Terpakai " + (option.usedCount || 0) + " user";
        }

        if (option.isFull) {
          return "Penuh · Limit " + option.limitUser + " user";
        }

        return "Sisa " + option.remaining + " slot · Terpakai " + (option.usedCount || 0) + "/" + option.limitUser + " user";
      }

      function getStatusText(option) {
        if (option.isFull) {
          return "Penuh";
        }

        if (option.isUnlimited) {
          return "Unlimited";
        }

        return "Sisa " + option.remaining;
      }

      function renderDropdown(keyword) {
        if (!dropdown) {
          return;
        }

        const searchKeyword = String(keyword || "").toLowerCase().trim();

        const filtered = bagianOptions.filter(function (option) {
          return String(option.nama || "").toLowerCase().includes(searchKeyword);
        });

        dropdown.innerHTML = "";

        if (filtered.length === 0) {
          dropdown.innerHTML = `
            <div class="empty_dropdown">
              Tidak ada bagian yang sesuai.
            </div>
          `;
          return;
        }

        filtered.forEach(function (option) {
          const button = document.createElement("button");

          button.type = "button";
          button.className = option.isFull
            ? "dropdown_option disabled"
            : "dropdown_option";

          button.innerHTML = `
            <div class="dropdown_icon ${option.isFull ? "full" : ""}">
              <span class="material-symbols-rounded">
                ${option.isFull ? "block" : "business_center"}
              </span>
            </div>

            <div class="dropdown_text">
              <strong>${escapeHTML(option.nama)}</strong>
              <small>${escapeHTML(getBagianDescription(option))}</small>
            </div>

            <span class="status_pill ${option.isFull ? "status_full" : "status_available"}">
              ${escapeHTML(getStatusText(option))}
            </span>
          `;

          if (!option.isFull) {
            button.addEventListener("click", function () {
              hiddenInput.value = option.nama;
              searchInput.value = option.nama;
              dropdown.classList.add("hidden");
              updateSubmitState();
            });
          }

          dropdown.appendChild(button);
        });
      }

      function openDropdown() {
        if (!dropdown) {
          return;
        }

        renderDropdown(searchInput.value);
        dropdown.classList.remove("hidden");
      }

      function closeDropdown() {
        if (dropdown) {
          dropdown.classList.add("hidden");
        }
      }

      function clearBagian() {
        if (hiddenInput) {
          hiddenInput.value = "";
        }

        if (searchInput) {
          searchInput.value = "";
          searchInput.focus();
        }

        renderDropdown("");

        if (dropdown) {
          dropdown.classList.remove("hidden");
        }

        updateSubmitState();
      }

      if (usernameInput) {
        usernameInput.addEventListener("input", function () {
          usernameInput.value = usernameInput.value.replace(/\D/g, "").slice(0, 18);
          updateSubmitState();
        });
      }

      if (searchInput) {
        searchInput.addEventListener("focus", openDropdown);
        searchInput.addEventListener("click", openDropdown);

        searchInput.addEventListener("input", function () {
          hiddenInput.value = "";
          renderDropdown(searchInput.value);

          if (dropdown) {
            dropdown.classList.remove("hidden");
          }

          updateSubmitState();
        });

        searchInput.addEventListener("keydown", function (event) {
          if (event.key === "Enter") {
            event.preventDefault();

            const keyword = String(searchInput.value || "").toLowerCase().trim();

            const firstAvailable = bagianOptions.find(function (option) {
              return !option.isFull &&
                String(option.nama || "").toLowerCase().includes(keyword);
            });

            if (firstAvailable) {
              hiddenInput.value = firstAvailable.nama;
              searchInput.value = firstAvailable.nama;
              closeDropdown();
              updateSubmitState();
            }
          }

          if (event.key === "Escape") {
            closeDropdown();
          }
        });
      }

      if (clearBtn) {
        clearBtn.addEventListener("click", clearBagian);
      }

      document.addEventListener("click", function (event) {
        const isInside = event.target.closest(".search_select");

        if (!isInside) {
          closeDropdown();
        }
      });

      if (form) {
        form.addEventListener("submit", function (event) {
          const nipValid = isNipValid();
          const bagianValid = isBagianValid();

          if (!nipValid || !bagianValid) {
            event.preventDefault();
            updateSubmitState();

            if (!nipValid) {
              usernameInput.focus();
              alert("NIP harus tepat 18 digit angka.");
              return;
            }

            if (!bagianValid) {
              openDropdown();
              searchInput.focus();
              alert("Silakan pilih bagian terlebih dahulu.");
            }
          }
        });
      }

      updateSubmitState();
    })();
  </script>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>