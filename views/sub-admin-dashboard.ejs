<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">

  <title>
    <%= process.env.APP_TITLE || 'Dashboard Sub Admin Sinosuke Lappari' %>
  </title>

  <meta name="viewport" content="width=device-width, initial-scale=1">

  <link
    href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,0,0"
    rel="stylesheet"
  >

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
    rel="stylesheet"
  >
  <script src="/secure-js/dashboard/theme.js"></script>
  <link rel="stylesheet" href="/css/style.css">
  <!-- Letakkan script ini di <head>, SEBELUM <link rel="stylesheet" href="/css/style.css"> -->
<script>
  (function () {
    try {
      var savedTheme = localStorage.getItem("sinosuke_theme") || "dark";
      var root = document.documentElement;

      root.classList.remove("theme-light", "theme-dark");
      root.classList.add(savedTheme === "light" ? "theme-light" : "theme-dark");
      root.setAttribute("data-theme", savedTheme === "light" ? "light" : "dark");
    } catch (error) {
      document.documentElement.classList.add("theme-dark");
      document.documentElement.setAttribute("data-theme", "dark");
    }
  })();
</script>

</head>

<body class="sinosuke-body">

<%
  const safeUser = typeof user !== "undefined" && user ? user : {};
  const safeUserData = typeof userData !== "undefined" && userData ? userData : safeUser;

  const safeUsers = typeof users !== "undefined" && Array.isArray(users) ? users : [];
  const safeSuratList = typeof suratList !== "undefined" && Array.isArray(suratList) ? suratList : [];
  const safeSuratSayaList = typeof suratSayaList !== "undefined" && Array.isArray(suratSayaList) ? suratSayaList : [];

  const safeWhitelistList = typeof whitelistList !== "undefined" && Array.isArray(whitelistList) ? whitelistList : [];
  const safeBagianDibawahi = typeof bagianDibawahi !== "undefined" && Array.isArray(bagianDibawahi) ? bagianDibawahi : [];

  const safeTotalSuratUser = typeof totalSuratUser !== "undefined" ? totalSuratUser : safeSuratSayaList.length;
  const safeTotalSuratBawahan = typeof totalSuratBawahan !== "undefined" ? totalSuratBawahan : safeSuratList.length;

  const safeSuccess = typeof success !== "undefined" && Array.isArray(success) ? success : [];
  const safeError = typeof error !== "undefined" && Array.isArray(error) ? error : [];

  const safeAppConfig = typeof appConfig !== "undefined" && appConfig ? appConfig : {};
  const safeSpreadsheetUrl = typeof spreadsheetUrl !== "undefined" && spreadsheetUrl
    ? spreadsheetUrl
    : safeAppConfig.spreadsheetUrl || "";

  const allowedSections = [
    "dashboard",
    "buat-surat",
    "profile",
    "surat-saya",
    "akun-staf",
    "whitelist",
    "surat-bawahan",
    "sheet"
  ];

  const requestedSection = typeof activeSection !== "undefined" && activeSection
    ? activeSection
    : "dashboard";

  const safeActiveSection = allowedSections.includes(requestedSection)
    ? requestedSection
    : "dashboard";

  const safeSubAdminTitle = safeUser.subAdminGroup || safeUser.bagian || "SUB ADMIN";

  const headerTitleMap = {
    "dashboard": "Dashboard Sub Admin Sinosuke Lappari",
    "buat-surat": "Buat Surat",
    "profile": "Profil Akun",
    "surat-saya": "Surat Saya",
    "akun-staf": "Data Akun Staf",
    "whitelist": "Whitelist Username/NIP",
    "surat-bawahan": "Data Surat Staf",
    "sheet": "Data Spreadsheet"
  };

  const headerSubtitleMap = {
    "dashboard": "Sistem Penomoran Surat Keluar Lapas Pariaman",
    "buat-surat": "Buat nomor surat baru sebagai sub admin",
    "profile": "Kelola informasi akun dan password",
    "surat-saya": "Lihat riwayat surat yang pernah Anda buat",
    "akun-staf": "Kelola akun staf yang berada di bawah kewenangan Anda",
    "whitelist": "Kelola username atau NIP yang diizinkan mendaftar",
    "surat-bawahan": "Pantau surat dari staf yang berada di bawah kewenangan Anda",
    "sheet": "Lihat data Google Spreadsheet"
  };

  function buildSheetRowUrl(surat) {
    if (!surat) {
      return "";
    }

    if (surat.sheetRowUrl) {
      return surat.sheetRowUrl;
    }

    const spreadsheetUrlValue = surat.spreadsheetUrl || safeSpreadsheetUrl || "";
    const sheetGid = surat.sheetGid || "";
    const sheetRow = surat.sheetRow || "";

    if (!spreadsheetUrlValue || !sheetGid || !sheetRow) {
      return "";
    }

    const cleanUrl = String(spreadsheetUrlValue).split("#")[0];

    return cleanUrl + "#gid=" + sheetGid + "&range=A" + sheetRow;
  }
%>

  <div id="toast_container" class="toast_container"></div>

  <div class="app_window">

    <%- include("partials/sub-admin-sidebar.ejs", {
      activeMenu: safeActiveSection
    }) %>

    <main class="main_content">

      <%- include("partials/header.ejs", {
        headerTitle: headerTitleMap[safeActiveSection] || "Dashboard",
        headerSubtitle: headerSubtitleMap[safeActiveSection] || "Sistem Penomoran Surat Keluar Lapas Pariaman"
      }) %>

      <section class="view_container">
        <div class="dashboard_scroll">

          <textarea id="subAdminFlashMessagesJson" hidden><%= JSON.stringify({
            success: safeSuccess,
            error: safeError
          }) %></textarea>

          <% if (safeActiveSection === "dashboard") { %>

            <%- include("partials/sub-admin/hero-section.ejs", {
              safeUser: safeUser,
              safeSubAdminTitle: safeSubAdminTitle,
              safeBagianDibawahi: safeBagianDibawahi
            }) %>

            <%- include("partials/sub-admin/statistic-section.ejs", {
              safeUsers: safeUsers,
              safeWhitelistList: safeWhitelistList,
              safeTotalSuratUser: safeTotalSuratUser,
              safeTotalSuratBawahan: safeTotalSuratBawahan
            }) %>

          <% } else if (safeActiveSection === "buat-surat") { %>

            <%- include("partials/sub-admin/form-surat-section.ejs", {
              safeUser: safeUser,
              safeSubAdminTitle: safeSubAdminTitle,
              safeAppConfig: safeAppConfig,
              safeTotalSuratUser: safeTotalSuratUser
            }) %>

          <% } else if (safeActiveSection === "profile") { %>

            <%- include("partials/shared/profile-section.ejs", {
              safeUserData: safeUserData,
              safeSuccess: safeSuccess,
              safeError: safeError
            }) %>

          <% } else if (safeActiveSection === "surat-saya") { %>

            <%- include("partials/shared/surat-saya-section.ejs", {
              safeSuratList: safeSuratSayaList,
              safeAppConfig: safeAppConfig,
              buildSheetRowUrl: buildSheetRowUrl
            }) %>

          <% } else if (safeActiveSection === "akun-staf") { %>

            <%- include("partials/sub-admin/akun-staf-section.ejs", {
              safeUsers: safeUsers
            }) %>

          <% } else if (safeActiveSection === "whitelist") { %>

            <%- include("partials/sub-admin/whitelist-section.ejs", {
              safeWhitelistList: safeWhitelistList
            }) %>

          <% } else if (safeActiveSection === "surat-bawahan") { %>

            <%- include("partials/sub-admin/surat-bawahan-section.ejs", {
              safeSuratList: safeSuratList,
              buildSheetRowUrl: buildSheetRowUrl
            }) %>

          <% } else if (safeActiveSection === "sheet") { %>

            <%- include("partials/sub-admin/spreadsheet-section.ejs", {
              safeSpreadsheetUrl: safeSpreadsheetUrl
            }) %>

          <% } %>

        </div>
      </section>

      <%- include("partials/footer.ejs") %>

    </main>
  </div>

  <%- include("partials/sub-admin/confirm-modal.ejs") %>

  <%- include("partials/sub-admin/inline-style.ejs") %>

  <script>
    window.DASHBOARD_CONFIG = {
      userBagian: "<%= safeSubAdminTitle %>",
      userNama: "<%= safeUser && safeUser.nama ? safeUser.nama : '' %>",
      username: "<%= safeUser && safeUser.username ? safeUser.username : '' %>",
      kodeSatker: "<%= safeAppConfig.kodeSatker || process.env.KODE_SATKER || 'WP.3.PAS.4-' %>"
    };
  </script>
<%- include("partials/sub-admin/confirm-modal.ejs") %>

<%- include("partials/sub-admin/inline-style.ejs") %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

<script src="/secure-js/dashboard/config.js"></script>
<script src="/secure-js/dashboard/ui-utils.js"></script>
<!-- <script src="/secure-js/dashboard/theme.js"></script> -->
<script src="/secure-js/dashboard/surat-api.js"></script>
<script src="/secure-js/dashboard/search-dropdown.js"></script>
<script src="/secure-js/dashboard/form-submit.js"></script>
<script src="/secure-js/dashboard/profile.js"></script>
<script src="/secure-js/dashboard/main.js"></script>

<%- include("partials/sub-admin/inline-script.ejs") %>

  <script>
    if (window.ProfileUI) {
      window.ProfileUI.init();
    }
  </script>

</body>
</html>